@model UsersIndexViewModel
@inject IMediator Mediator
@{
    ViewData["Title"] = "Usuarios";
}

<div class="pagetitle">
    <h1>@ViewData["Title"]</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Inicio</a></li>
            <li class="breadcrumb-item active">@ViewData["Title"]</li>
        </ol>
    </nav>
</div>

<section class="section dashboard">

    <div class="card">

        <div class="card-header">
            <div class="row">
                <h3 class="m-0 font-weight-bold text-primary col-md-11">@ViewData["Title"]</h3>

                @if (await Mediator.Send(new UserHasPermissionQuery 
                { 
                    UserId = User.FindFirstValue(ClaimTypes.NameIdentifier),
                    PermissionCode = PermissionCodesCatalog.CREATE_USERS
                }))
                {
                    <div class="col-md-1">
                        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i></a>
                    </div>
                }
            </div>
        </div>

        <div class="card-body mt-3">

            <form method="GET" asp-action="Index" class="row g-2 align-items-end mb-4">
                <input type="hidden" name="page" value="1" />

                <div class="col-md-3">
                    <label class="form-label small text-muted mb-0">Nombre / Correo:</label>
                    <input type="text"
                           name="nameFilter"
                           class="form-control"
                           value="@Model.FilterName"
                           placeholder="Buscar..." />
                </div>

                <div class="col-md-2">
                    <label class="form-label small text-muted mb-0">Rol</label>
                    <select name="roleIdFilter" class="form-select">
                        <option value="">Todos</option>
                        @foreach (var role in Model.Roles)
                        {
                            <option value="@role.Id" selected="@(Model.FilterRoleId == role.Id)">@role.Name</option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label small text-muted mb-0">Por página</label>
                    @{
                        int[] pageSizePresets = new[] { 5, 10, 20, 50 };
                        int currentPageSize = Model.List.PageSize;
                    }
                    <select name="pageSize" class="form-select">
                        @foreach (int size in pageSizePresets)
                        {
                            <option value="@size" selected="@(currentPageSize == size)">@size</option>
                        }
                    </select>
                </div>

                <div class="col-md-5">
                    <button type="submit" class="btn btn-primary">Filtrar</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
                </div>
            </form>

            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Correo</th>
                        <th>Rol</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.List.Items)
                    {
                        <tr>
                            <td>@item.FirstName @item.LastName</td>
                            <td>@item.Email</td>
                            <td>@item.RoleName</td>
                            <td>
                                @if (await Mediator.Send(new UserHasPermissionQuery 
                                { 
                                    UserId = User.FindFirstValue(ClaimTypes.NameIdentifier),
                                    PermissionCode = PermissionCodesCatalog.EDIT_USERS
                                }))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                }

                                @if (await Mediator.Send(new UserHasPermissionQuery 
                                { 
                                    UserId = User.FindFirstValue(ClaimTypes.NameIdentifier),
                                    PermissionCode = PermissionCodesCatalog.DELETE_USERS
                                }))
                                {
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="POST" style="display: contents;">
                                        <button type="submit" class="btn btn-sm btn-danger btnDelete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (Model.List.TotalPages > 1)
            {
                <nav>
                    <ul class="pagination justify-content-center mb-0">
                        <li class="page-item @(Model.List.HasPreviousPage ? "" : "disabled")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(Model.List.PageNumber - 1)"
                               asp-route-pageSize="@Model.List.PageSize"
                               asp-route-nameFilter="@Model.FilterName"
                               asp-route-roleIdFilter="@Model.FilterRoleId">
                                <span aria-hidden="true">Anterior</span>
                            </a>
                        </li>
                        <li class="page-item disabled">
                            <span class="page-link">@Model.List.PageNumber / @Model.List.TotalPages</span>
                        </li>
                        <li class="page-item @(Model.List.HasNextPage ? "" : "disabled")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(Model.List.PageNumber + 1)"
                               asp-route-pageSize="@Model.List.PageSize"
                               asp-route-nameFilter="@Model.FilterName"
                               asp-route-roleIdFilter="@Model.FilterRoleId">
                                <span aria-hidden="true">Siguiente</span>
                            </a>
                        </li>
                    </ul>
                </nav>
                <p class="text-muted text-center small mt-2 mb-0">@Model.List.TotalCount registros</p>
            }

        </div>
    </div>
</section>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.btnDelete').click(function (event) {
                event.preventDefault();
                Swal.fire({
                    icon: "question",
                    title: "¿Desea eliminar el usuario?",
                    text: "No podrá revertirlo",
                    showCancelButton: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        const form = $(this).closest('form');
                        form.submit();
                    }
                });
            });
        });
    </script>
}