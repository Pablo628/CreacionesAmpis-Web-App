@model BlogEditViewModel
@{
    ViewData["Title"] = "Editar blog";
}

@section Styles {
    <link href="~/lib/summernote/summernote-bs5.css" rel="stylesheet" asp-append-version="true" />
}

<div class="pagetitle">
    <h1>Dashboard</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Inicio</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Blogs</a></li>
            <li class="breadcrumb-item active">Editar blog</li>
        </ol>
    </nav>
</div>

<section class="section dashboard">
    <div class="card">

        <div class="card-header">
            <h3 class="m-0 font-weight-bold text-primary">Editar blog</h3>
        </div>

        <div class="card-body mt-3">

            <form id="blog-edit-form" asp-action="Edit" method="post" class="row g-3">
                <input type="hidden" asp-for="Blog.Id" />

                <div class="col-md-12">
                    <div class="form-floating">
                        <input asp-for="Blog.Name" class="form-control" placeholder="Título" />
                        <label asp-for="Blog.Name"></label>
                        <span asp-validation-for="Blog.Name" class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-12">
                    <label asp-for="Blog.Content" class="form-label"></label>
                    <textarea asp-for="Blog.Content" id="Blog_Content" class="form-control" rows="10"></textarea>
                    <span asp-validation-for="Blog.Content" class="text-danger"></span>
                </div>

                <div class="col-md-8">
                    <label asp-for="Blog.SectionId" class="form-label"></label>
                    <select asp-for="Blog.SectionId" class="form-select">
                        <option value="">— Seleccione —</option>
                        @foreach (var sec in Model.SectionOptions)
                        {
                            <option value="@sec.Id">@sec.Name</option>
                        }
                    </select>
                    <span asp-validation-for="Blog.SectionId" class="text-danger"></span>
                </div>

                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check form-switch">
                        <input asp-for="Blog.IsPublished" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="Blog.IsPublished" class="form-check-label"></label>
                    </div>
                </div>

                <div class="text-center mt-3">
                    <button class="btn btn-primary" type="submit">Guardar</button>
                    <a asp-action="Index" class="btn btn-secondary">Volver</a>
                </div>

            </form>

        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/lib/summernote/summernote-bs5.js" asp-append-version="true"></script>
    <script src="~/lib/summernote/lang/summernote-es-ES.js" asp-append-version="true"></script>

    <script>
        $(function () {
        var $editor = $('#Blog_Content');

        $editor.summernote({
        lang: 'es-ES',
        placeholder: 'Escriba el contenido del blog…',
        height: 280,
        dialogsInBody: true
        });

        $('#blog-edit-form').on('submit', function () {
        var html = $editor.summernote('code');
        $editor.val(html);
        });
        });
    </script>
}