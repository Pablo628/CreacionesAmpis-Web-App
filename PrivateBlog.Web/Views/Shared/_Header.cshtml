@inject IMediator Mediator

@{
    PrivateBlog.Application.UseCases.Account.Queries.GetAccountUserInfo.UserAccountInfoDTO? user = null;

    try
    {
        if (User.Identity?.IsAuthenticated == true)
        {
            string? userId = User.FindFirstValue(ClaimTypes.NameIdentifier);

            if (!string.IsNullOrWhiteSpace(userId))
            {
                user = await Mediator.Send(new PrivateBlog.Application
                                                          .UseCases
                                                          .Account
                                                          .Queries
                                                          .GetAccountUserInfo
                                                          .GetAccountUserInfoQuery{ UserId = userId });
            }
        }
    }
    catch
    {
        user = null;        
    }

}

<header id="header" class="header fixed-top d-flex align-items-center">

    <div class="d-flex align-items-center justify-content-between">
        <a asp-controller="Home" asp-action="Index" class="logo d-flex align-items-center">
            <img src="assets/img/logo.png" alt="">
            <span class="d-none d-lg-block">NiceAdmin</span>
        </a>
        <i class="bi bi-list toggle-sidebar-btn"></i>
    </div><!-- End Logo -->

    <nav class="header-nav ms-auto">
        <ul class="d-flex align-items-center">

            <li class="nav-item dropdown pe-3">

                @if(user is not null)
                {                    
                    <a class="nav-link nav-profile d-flex align-items-center pe-0" href="#" data-bs-toggle="dropdown">
                        <img src="assets/img/profile-img.jpg" alt="Profile" class="rounded-circle">
                        <span class="d-none d-md-block dropdown-toggle ps-2">
                            @(user.FirstName.Substring(0, 1)). @user.LastName
                        </span>
                    </a>

                    <ul class="dropdown-menu dropdown-menu-end dropdown-menu-arrow profile">
                        <li class="dropdown-header">
                            <h6>@user.FullName</h6>
                            <span>@user.RoleName</span>
                        </li>
                        <li>
                            <hr class="dropdown-divider">
                        </li>

                        <li>
                            <a class="dropdown-item d-flex align-items-center" href="users-profile.html">
                                <i class="bi bi-person"></i>
                                <span>Mi Perfil</span>
                            </a>
                        </li>
                        <li>
                            <hr class="dropdown-divider">
                        </li>

                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="POST" class="px-0 mb-0">
                                <button type="submit" class="dropdown-item d-flex align-items-center border-0 bg-transparent w-100 text-start">
                                    <i class="bi bi-box-arrow-right"></i>
                                    <span>Cerrar sesión</span>
                                </button>
                            </form>
                        </li>

                    </ul>
                }
                else
                {
                    <a class="dropdown-item d-flex align-items-center" asp-controller="Account" asp-action="Login">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Iniciar sesión</span>
                    </a>
                }
            </li>

        </ul>
    </nav>

</header>